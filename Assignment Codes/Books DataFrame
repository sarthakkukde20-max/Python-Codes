import pandas as pd

# Read CSV file
df = pd.read_csv("books.csv")

print("\nComplete Report of Books")
print(df)

# a) Books of given author
author = input("\nEnter Author Name: ")
print("\nBooks by Author:")
print(df[df["Author"] == author])

# b) Books of given publisher
publisher = input("\nEnter Publisher Name: ")
print("\nBooks by Publisher:")
print(df[df["Publisher"] == publisher])

# c) Cheapest and Costliest book
cheapest = df.loc[df["Price"].idxmin()]
costliest = df.loc[df["Price"].idxmax()]

print("\nCheapest Book:")
print(cheapest["Title"], "-", cheapest["Price"])

print("\nCostliest Book:")
print(costliest["Title"], "-", costliest["Price"])

# d) Sort by year
print("\nBooks Sorted by Year")
print(df.sort_values(by="Year"))
